{
  "kind": "collectionType",
  "collectionName": "methodical_series",
  "info": {
    "singularName": "methodical-series",
    "pluralName": "methodische-reihen",
    "displayName": "Methodical Series",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "goal": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Technik",
        "Taktik",
        "Kondition",
        "Mental"
      ],
      "required": true
    },
    "exercises": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::exercise.exercise",
      "mappedBy": "methodicalSeries"
    },
    "playerProgresses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::player-progress.player-progress",
      "mappedBy": "methodicalSeries"
    },
    "trainings": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::training.training",
      "mappedBy": "methodicalSeries"
    }
  }
}
