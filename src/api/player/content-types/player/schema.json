{
  "kind": "collectionType",
  "collectionName": "players",
  "info": {
    "singularName": "player",
    "pluralName": "players",
    "displayName": "Player",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string"
    },
    "trainings": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::training.training",
      "mappedBy": "players"
    },
    "QTTR": {
      "type": "integer"
    },
    "dateofbirth": {
      "type": "date"
    },
    "playerlevel": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::playerlevel.playerlevel",
      "inversedBy": "players"
    },
    "teams": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team.team",
      "mappedBy": "players"
    },
    "traininggroups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::traininggroup.traininggroup",
      "mappedBy": "players"
    },
    "Playerlog": {
      "type": "dynamiczone",
      "components": [
        "playerlog.trainingscamp",
        "playerlog.trainertable",
        "playerlog.competition"
      ]
    },
    "Material": {
      "type": "dynamiczone",
      "components": [
        "material.racket"
      ]
    }
  }
}
