{
  "kind": "collectionType",
  "collectionName": "trainings",
  "info": {
    "singularName": "training",
    "pluralName": "trainings",
    "displayName": "Training",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string"
    },
    "Date": {
      "type": "date"
    },
    "players": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::player.player",
      "inversedBy": "trainings"
    },
    "sequences": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sequence.sequence",
      "inversedBy": "trainings"
    },
    "training_status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "in_progress",
        "completed"
      ],
      "default": "draft"
    },
    "startedAt": {
      "type": "datetime"
    }
  }
}
