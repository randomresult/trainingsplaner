{
  "kind": "collectionType",
  "collectionName": "player_progresses",
  "info": {
    "singularName": "player-progress",
    "pluralName": "player-progresses",
    "displayName": "Player Progress",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "player": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::player.player",
      "inversedBy": "playerProgresses"
    },
    "training": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::training.training"
    },
    "exercises": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::exercise.exercise"
    },
    "pointsEarned": {
      "type": "integer",
      "default": 0
    },
    "completedAt": {
      "type": "datetime"
    },
    "methodicalSeries": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::methodical-series.methodical-series",
      "inversedBy": "playerProgresses"
    },
    "completedExercises": {
      "type": "json"
    },
    "lastUpdated": {
      "type": "datetime"
    },
    "notes": {
      "type": "text"
    },
    "mastered": {
      "type": "boolean"
    }
  }
}
